{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zovi-website",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      ".git",
      ".github",
      "scripts",
      "netlify.toml",
      "wrangler.jsonc",
      ".wrangler",
      ".gitignore"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
